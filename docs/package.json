{
    "name": "docs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsx ./scripts/fetch-github-stats.ts && node ./scripts/generate-registry.mjs && vite build",
        "cf-typegen": "wrangler types src/worker-configuration.d.ts",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "deploy": "pnpm run build && wrangler deploy",
        "dev": "vite dev",
        "examples-catalog:sync": "node ./scripts/sync-examples-catalog.mjs",
        "examples-catalog:watch": "chokidar 'src/routes/examples/**/+page.ts' --ignore 'src/routes/examples/+page.ts' -c 'node ./scripts/sync-examples-catalog.mjs' --initial --silent",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "prepare": "svelte-kit sync || echo ''",
        "preview": "pnpm run build && wrangler dev",
        "registry:generate": "node ./scripts/generate-registry.mjs",
        "registry:watch": "chokidar 'src/lib/shadcn/ui/**/*.svelte' 'src/lib/shadcn/ui/**/*.ts' -c 'node ./scripts/generate-registry.mjs' --initial --silent",
        "test": "npm run test:unit -- --run",
        "test:unit": "vitest"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@humanspeak/docs-kit": "github:humanspeak/docs-kit#2026.6.9",
        "@humanspeak/svelte-markdown": "^1.6.0",
        "@humanspeak/svelte-motion": "^0.7.7",
        "@humanspeak/svelte-scoped-props": "workspace:*",
        "@inlang/paraglide-js": "^2.20.1",
        "@lucide/svelte": "^1.21.0",
        "bits-ui": "^2.18.1",
        "flubber": "^0.4.2",
        "motion": "^12.40.0",
        "posthog-js": "^1.392.0",
        "posthog-node": "^5.38.2",
        "runed": "^0.37.1"
    },
    "devDependencies": {
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/kit": "^2.66.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.1",
        "@types/flubber": "^0.4.0",
        "@vitest/browser": "^4.1.9",
        "chokidar-cli": "^3.0.0",
        "clsx": "^2.1.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-svelte": "3.19.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "globals": "^17.7.0",
        "mdsvex": "^0.12.7",
        "mode-watcher": "^1.1.0",
        "playwright": "^1.61.0",
        "prettier": "^3.8.4",
        "prettier-plugin-sort-json": "^4.2.0",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "shiki": "^4.2.0",
        "svelte": "^5.56.4",
        "svelte-check": "^4.6.0",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.3.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.0.16",
        "vite-plugin-devtools-json": "^1.0.0",
        "vitest": "^4.1.9",
        "vitest-browser-svelte": "^2.1.1",
        "wrangler": "^4.103.0"
    },
    "volta": {
        "node": "24.15.0"
    },
    "pnpm": {}
}
